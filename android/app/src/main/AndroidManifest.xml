<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- =========================================================================
         PR-J: PERMISSIONS AUDIT — each permission documented with justification.

         MiValta is a privacy-first fitness coaching app. All data stays on-device
         in an encrypted vault (SQLCipher). No cloud sync, no third-party analytics.

         PERMISSION CATEGORIES:
         1. HEALTH: Read-only access to Health Connect biometrics
         2. FOREGROUND SERVICE: Required for Health Connect on Android 14+

         NETWORK: NONE. MiValta does not request INTERNET permission. The app
         cannot connect to any server. All computation happens on-device. When
         the conversational AI ships (model W), it will be delivered via Play
         Asset Delivery — no runtime network access needed.
         ========================================================================= -->

    <!-- =======================================================================
         HEALTH CONNECT — READ PERMISSIONS

         WHY NEEDED: MiValta reads biometrics to calculate readiness/fatigue.
         - Resting HR: cardiovascular recovery indicator
         - HRV (RMSSD): autonomic nervous system balance
         - Sleep stages: recovery quality assessment
         - Oxygen saturation: supplementary recovery metric
         - Steps: activity volume estimation

         READ-ONLY: MiValta never writes to Health Connect.

         DATA FLOW: Health Connect → Rust normalizer → encrypted vault (on-device).
         No data leaves the device.
         ======================================================================= -->
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_RESTING_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE_VARIABILITY" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" />
    <uses-permission android:name="android.permission.health.READ_OXYGEN_SATURATION" />
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <!-- READ_EXERCISE: workout sessions bound the intra-workout HR window for
         time-in-zone (HealthDataType.WORKOUT). Read-only; samples are binned
         on-device by the engine. -->
    <uses-permission android:name="android.permission.health.READ_EXERCISE" />

    <!-- =======================================================================
         BLUETOOTH LOW ENERGY — HEART-RATE STRAP (D1-B)

         WHY NEEDED: pair a BLE HR strap (Polar H10, Garmin/Wahoo, ANT+/BLE) to
         capture live heart rate during a workout (HR Service 0x180D).
         READ-ONLY: MiValta only reads the HR characteristic; it never writes.
         neverForLocation: MiValta does not derive location from BLE scans, so
         Android 12+ can skip the ACCESS_FINE_LOCATION requirement.
         DATA FLOW: strap → engine normalizer → encrypted vault (on-device).
         ======================================================================= -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false" />

    <!-- =======================================================================
         FOREGROUND SERVICE — HEALTH

         WHY NEEDED: Android 14+ requires foreground service for Health Connect.
         - Allows background sync of health data when app is not in foreground
         - Required by the `health` Flutter plugin

         NO PERSISTENT SERVICE: App does not run a persistent background service.
         Health sync happens when user opens the app.
         ======================================================================= -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_HEALTH" />

    <!-- =======================================================================
         POST_NOTIFICATIONS — BS-012 morning read

         WHY NEEDED: Android 13+ (API 33) requires this runtime permission
         before any notification is shown. Without it every morning read is
         silently dropped by the OS. Requested at runtime in
         NotificationService.initialize(); the athlete can always refuse —
         presence=off in the app is the in-product equivalent.
         ======================================================================= -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- FL-17: on-device-only posture. Disable cloud/Auto Backup so the
         SQLCipher vault (and its file-backed key) under filesDir cannot be
         copied to Google Drive or a new device. allowBackup=false also disables
         D2D transfer of app data; fullBackupContent guards pre-API-31 devices.
         Entry AM defense-in-depth: dataExtractionRules is the API-31+ control
         (explicit excludes in res/xml/data_extraction_rules.xml), so the
         vault-free-backup posture holds even if allowBackup is ever flipped. -->
    <application
        android:label="MiValta"
        android:name="${applicationName}"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher">
        <!-- Portrait-only for beta. Two-pane landscape deferred post-beta
             (design in Responsive-Orientation.html). -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:screenOrientation="portrait"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

            <!-- Health Connect: permission rationale activity.
                 Allows Health Connect settings to launch the app when user
                 reviews permissions. -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
                <!-- FL-19: scope the filter with a category so only an explicit
                     (Health Connect) intent resolves it, not a bare action match. -->
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <meta-data
                android:name="health_permissions"
                android:resource="@array/health_permissions" />
        </activity>

        <!-- Health Connect: permission rationale activity alias for Android 14+ -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
