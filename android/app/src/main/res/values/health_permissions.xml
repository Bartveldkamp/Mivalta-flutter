<?xml version="1.0" encoding="utf-8"?>
<!-- PR-E: Health Connect permission declarations for Android.
     These are the data types MiValta reads from Health Connect.

     Current ingestion (biometrics drive readiness):
       - Resting heart rate
       - HRV (RMSSD)
       - Sleep stages
       - Oxygen saturation
       - Steps

     Deferred (exerciseType impedance mismatch — needs engine PR):
       - Exercise / workout sessions -->
<resources>
    <array name="health_permissions">
        <item>android.permission.health.READ_HEART_RATE</item>
        <item>android.permission.health.READ_RESTING_HEART_RATE</item>
        <item>android.permission.health.READ_HEART_RATE_VARIABILITY</item>
        <item>android.permission.health.READ_SLEEP</item>
        <item>android.permission.health.READ_OXYGEN_SATURATION</item>
        <item>android.permission.health.READ_STEPS</item>
    </array>
</resources>
